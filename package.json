{
    "name": "tan-stack-start-full-stack-template",
    "private": true,
    "type": "module",
    "scripts": {
        "postinstall": "([ -z \"$CI\" ] && npm dedupe --quiet || true)",
        "check": "npm run format:check && npm run lint:check && npm run spell:check && npm run type:check && npm run usage:check && npm run commitlint:check",
        "commitlint:check": "commitlint --from HEAD~1 --to HEAD",
        "dev": "vite dev --port 3000",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "drizzle-kit generate && prettier --write drizzle/",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:pull": "drizzle-kit pull",
        "db:studio": "drizzle-kit studio",
        "graphql:generate": "graphql-codegen --config codegen.ts",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "spell:check": "cspell . --no-progress",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "storybook build",
        "type:check": "npm exec tsc -- --noEmit",
        "usage:check": "knip",
        "prepare": "husky"
    },
    "dependencies": {
        "@apollo/server": "^5.5.1",
        "@graphql-tools/schema": "^10.0.33",
        "@graphql-typed-document-node/core": "^3.2.0",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-devtools": "^0.10.5",
        "@tanstack/react-form": "^1.32.0",
        "@tanstack/react-router": "^1.169.2",
        "@tanstack/react-router-devtools": "^1.166.13",
        "@tanstack/react-router-ssr-query": "^1.166.12",
        "@tanstack/react-start": "^1.167.65",
        "@tanstack/router-plugin": "^1.167.35",
        "ai": "^6.0.182",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "graphql": "^16.14.0",
        "graphql-scalars": "^1.25.0",
        "graphql-sse": "^2.6.0",
        "graphql-subscriptions": "^3.0.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^1.16.0",
        "next-themes": "^0.4.6",
        "pg": "^8.20.0",
        "pg-boss": "^12.18.2",
        "playwright": "^1.60.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.6",
        "react-day-picker": "^10.0.0",
        "react-dom": "^19.2.6",
        "sonner": "^2.0.7",
        "streamdown": "^2.5.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "urql": "^5.0.2",
        "vaul": "^1.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@cspell/dict-de-de": "^4.1.2",
        "@graphql-codegen/cli": "^7.0.0",
        "@graphql-codegen/client-preset": "^6.0.0",
        "@graphql-codegen/typed-document-node": "^7.0.0",
        "@graphql-codegen/typescript": "^6.0.1",
        "@graphql-codegen/typescript-operations": "^6.0.2",
        "@graphql-codegen/typescript-resolvers": "^6.0.1",
        "@rsbuild/core": "^2.0.6",
        "@storybook/addon-docs": "^10.4.0",
        "@storybook/builder-vite": "^10.4.0",
        "@storybook/react-vite": "^10.4.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tanstack/devtools-vite": "^0.7.0",
        "@tanstack/eslint-config": "^0.4.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^24.12.2",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "cspell": "^10.0.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "graphql-codegen-typescript-validation-schema": "^0.19.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "knip": "^6.13.1",
        "prettier": "^3.8.3",
        "storybook": "^10.4.0",
        "tsx": "^4.22.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.13",
        "vitest": "^4.1.6"
    },
    "packageManager": "npm@11.12.0",
    "engines": {
        "node": "^24.14.0",
        "npm": "^11.12.0",
        "pnpm": "please-use-npm",
        "yarn": "please-use-npm"
    }
}
